<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer shadow -->
    <item android:left="0dp" android:top="0dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <solid android:color="@color/neumorph_dark_shadow" />
        </shape>
    </item>
    
    <item android:left="8dp" android:top="8dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <solid android:color="@color/neumorph_light_shadow" />
        </shape>
    </item>
    
    <!-- Main track with primary color -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <solid android:color="@color/Primary" />
        </shape>
    </item>
    
    <!-- Thumb (right position) -->
    <item android:left="68dp" android:top="8dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="oval">
            <solid android:color="@color/Background" />
            <stroke android:width="2dp" android:color="@color/neumorph_light_shadow" />
        </shape>
    </item>
</layer-list>