<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark shadow -->
    <item android:left="0dp" android:top="0dp" android:right="3dp" android:bottom="3dp">
        <shape android:shape="oval">
            <solid android:color="@color/neumorph_dark_shadow" />
        </shape>
    </item>
    
    <!-- Light shadow -->
    <item android:left="3dp" android:top="3dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="oval">
            <solid android:color="@color/neumorph_light_shadow" />
        </shape>
    </item>
    
    <!-- Main thumb -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="oval">
            <solid android:color="@color/Background" />
        </shape>
    </item>
</layer-list>