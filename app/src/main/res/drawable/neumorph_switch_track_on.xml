<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark shadow -->
    <item android:left="0dp" android:top="0dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="15dp" />
            <solid android:color="@color/neumorph_dark_shadow" />
        </shape>
    </item>
    
    <!-- Light shadow -->
    <item android:left="4dp" android:top="4dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="15dp" />
            <solid android:color="@color/neumorph_light_shadow" />
        </shape>
    </item>
    
    <!-- Main track with primary color -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="15dp" />
            <solid android:color="@color/Primary" />
        </shape>
    </item>
</layer-list>