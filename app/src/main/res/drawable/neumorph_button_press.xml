<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <!-- Pressed state - inset shadow -->
            <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <solid android:color="@color/Background" />
                    <stroke android:width="1dp" android:color="@color/neumorph_dark_shadow" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <!-- Normal state - raised -->
        <layer-list>
            <item android:left="0dp" android:top="0dp" android:right="4dp" android:bottom="4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <solid android:color="@color/neumorph_dark_shadow" />
                </shape>
            </item>
            <item android:left="4dp" android:top="4dp" android:right="0dp" android:bottom="0dp">
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <solid android:color="@color/neumorph_light_shadow" />
                </shape>
            </item>
            <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <solid android:color="@color/Background" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>