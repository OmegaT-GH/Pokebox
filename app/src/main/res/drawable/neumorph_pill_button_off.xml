<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer shadow -->
    <item android:left="0dp" android:top="0dp" android:right="12dp" android:bottom="12dp">
        <shape android:shape="rectangle">
            <corners android:radius="40dp" />
            <solid android:color="@color/neumorph_dark_shadow" />
        </shape>
    </item>
    
    <item android:left="12dp" android:top="12dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="40dp" />
            <solid android:color="@color/neumorph_light_shadow" />
        </shape>
    </item>
    
    <!-- Main track -->
    <item android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <corners android:radius="40dp" />
            <solid android:color="@color/Background" />
            <stroke android:width="3dp" android:color="@color/neumorph_dark_shadow" />
        </shape>
    </item>
    
    <!-- Thumb (left position) - much larger -->
    <item android:left="12dp" android:top="12dp" android:right="132dp" android:bottom="12dp">
        <shape android:shape="oval">
            <solid android:color="@color/Background" />
            <stroke android:width="3dp" android:color="@color/neumorph_light_shadow" />
        </shape>
    </item>
</layer-list>