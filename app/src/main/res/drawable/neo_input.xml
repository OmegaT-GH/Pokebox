<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Light shadow (top-left) - inverted for pressed effect -->
    <item android:top="0dp" android:left="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neo_shadow_light"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <!-- Dark shadow (bottom-right) - inverted -->
    <item android:bottom="6dp" android:right="6dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neo_shadow_dark"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <!-- Inner surface -->
    <item android:top="3dp" android:left="3dp" android:bottom="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/LighterBackground"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
</layer-list>
