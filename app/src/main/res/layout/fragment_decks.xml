<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/Background">

    <soup.neumorphism.NeumorphCardView
        android:id="@+id/rlayet"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:neumorph_shadowElevation="6dp"
        app:neumorph_shadowColorLight="@color/neumorph_light_shadow"
        app:neumorph_shadowColorDark="@color/neumorph_dark_shadow"
        app:neumorph_backgroundColor="@color/Background"
        app:neumorph_shapeType="flat">

        <Button
            android:id="@+id/btPasteDecklist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:background="@android:color/transparent"
            android:textColor="@color/text_on_primary"
            android:textStyle="bold"
            android:stateListAnimator="@null"
            android:text="@string/paste_decklist" />
    </soup.neumorphism.NeumorphCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rviewdeck"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:padding="4dp"
        android:clipToPadding="false"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btDeckCheck" />

    <soup.neumorphism.NeumorphCardView
        android:id="@+id/btDeckCheck"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:neumorph_shadowElevation="6dp"
        app:neumorph_shadowColorLight="@color/neumorph_light_shadow"
        app:neumorph_shadowColorDark="@color/neumorph_dark_shadow"
        app:neumorph_backgroundColor="@color/Background"
        app:neumorph_shapeType="flat"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/rlay"
        app:layout_constraintTop_toBottomOf="@+id/rlayet">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="10dp"
            android:importantForAccessibility="no"
            android:src="@drawable/collbookmark" />
    </soup.neumorphism.NeumorphCardView>

    <soup.neumorphism.NeumorphCardView
        android:id="@+id/rlay"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/rviewdeck"
        app:layout_constraintEnd_toStartOf="@+id/btDeckCheck"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rlayet"
        app:neumorph_shadowElevation="4dp"
        app:neumorph_shadowColorLight="@color/neumorph_light_shadow"
        app:neumorph_shadowColorDark="@color/neumorph_dark_shadow"
        app:neumorph_backgroundColor="@color/Background"
        app:neumorph_shapeType="pressed">

        <Spinner
            android:id="@+id/spDeckCollections"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp" />
    </soup.neumorphism.NeumorphCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
