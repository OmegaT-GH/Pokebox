<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/Background"
    tools:ignore="Overdraw">

    <LinearLayout
        android:layout_marginTop="?attr/actionBarSize"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal">

            <soup.neumorphism.NeumorphCardView
                android:id="@+id/btOpenFilters"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:neumorph_shadowElevation="6dp"
                app:neumorph_shadowColorLight="@color/neumorph_light_shadow"
                app:neumorph_shadowColorDark="@color/neumorph_dark_shadow"
                app:neumorph_backgroundColor="@color/Background"
                app:neumorph_shapeType="flat">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="12dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/filter" />
            </soup.neumorphism.NeumorphCardView>

            <soup.neumorphism.NeumorphCardView
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_weight="9"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_gravity="center_vertical"
                app:neumorph_shadowElevation="4dp"
                app:neumorph_shadowColorLight="@color/neumorph_light_shadow"
                app:neumorph_shadowColorDark="@color/neumorph_dark_shadow"
                app:neumorph_backgroundColor="@color/Background"
                app:neumorph_shapeType="pressed">

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="@string/buscar"
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/text_primary"
                    android:background="@android:color/transparent"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="16sp"
                    tools:ignore="TextContrastCheck" />
            </soup.neumorphism.NeumorphCardView>

            <soup.neumorphism.NeumorphCardView
                android:id="@+id/btSearch"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:neumorph_shadowElevation="6dp"
                app:neumorph_shadowColorLight="@color/neumorph_light_shadow"
                app:neumorph_shadowColorDark="@color/neumorph_dark_shadow"
                app:neumorph_backgroundColor="@color/Background"
                app:neumorph_shapeType="flat">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="12dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/search" />
            </soup.neumorphism.NeumorphCardView>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp">

            <soup.neumorphism.NeumorphCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="16dp"
                app:neumorph_shadowElevation="4dp"
                app:neumorph_shadowColorLight="@color/neumorph_light_shadow"
                app:neumorph_shadowColorDark="@color/neumorph_dark_shadow"
                app:neumorph_backgroundColor="@color/Background"
                app:neumorph_shapeType="flat">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/textbold"
                    android:text="@string/ordenar_por"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:textSize="16sp" />
            </soup.neumorphism.NeumorphCardView>

            <soup.neumorphism.NeumorphCardView
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:neumorph_shadowElevation="4dp"
                app:neumorph_shadowColorLight="@color/neumorph_light_shadow"
                app:neumorph_shadowColorDark="@color/neumorph_dark_shadow"
                app:neumorph_backgroundColor="@color/Background"
                app:neumorph_shapeType="pressed">

                <Spinner
                    android:id="@+id/spOrdenar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp" />
            </soup.neumorphism.NeumorphCardView>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rviewfilteredsearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:clipToPadding="false" />

    </LinearLayout>

    <ScrollView
        android:id="@+id/scrFiltro"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/Background"
        android:padding="10dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:id="@+id/contFiltro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </ScrollView>

</androidx.drawerlayout.widget.DrawerLayout>
