<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/select_collection"
        android:layout_marginBottom="8dp"
        style="@style/textbold"
        android:textSize="14sp"/>

    <soup.neumorphism.NeumorphCardView
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="24dp"
        app:neumorph_shadowElevation="4dp"
        app:neumorph_shadowColorLight="@color/neumorph_light_shadow"
        app:neumorph_shadowColorDark="@color/neumorph_dark_shadow"
        app:neumorph_backgroundColor="@color/Background"
        app:neumorph_shapeType="pressed">

        <Spinner
            android:id="@+id/spColeccionesATC"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp" />
    </soup.neumorphism.NeumorphCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/in_collection"
        android:layout_marginBottom="8dp"
        style="@style/textbold"
        android:textSize="14sp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <soup.neumorphism.NeumorphCardView
            android:id="@+id/btMinus"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:neumorph_shadowElevation="6dp"
            app:neumorph_shadowColorLight="@color/neumorph_light_shadow"
            app:neumorph_shadowColorDark="@color/neumorph_dark_shadow"
            app:neumorph_backgroundColor="@color/Background"
            app:neumorph_shapeType="flat">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="-"
                android:textColor="@color/text_on_primary"
                android:textStyle="bold"
                android:textSize="24sp"/>
        </soup.neumorphism.NeumorphCardView>

        <TextView
            android:id="@+id/tvCantidad"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0"
            android:textAlignment="center"
            android:textSize="32sp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            style="@style/textboldbig"/>

        <soup.neumorphism.NeumorphCardView
            android:id="@+id/btPlus"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:neumorph_shadowElevation="6dp"
            app:neumorph_shadowColorLight="@color/neumorph_light_shadow"
            app:neumorph_shadowColorDark="@color/neumorph_dark_shadow"
            app:neumorph_backgroundColor="@color/Background"
            app:neumorph_shapeType="flat">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="+"
                android:textColor="@color/text_on_primary"
                android:textStyle="bold"
                android:textSize="24sp"/>
        </soup.neumorphism.NeumorphCardView>
    </LinearLayout>

</LinearLayout>