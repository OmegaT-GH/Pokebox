<?xml version="1.0" encoding="utf-8"?>
<soup.neumorphism.NeumorphCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:neumorph_shadowElevation="6dp"
    app:neumorph_shadowColorLight="@color/neumorph_light_shadow"
    app:neumorph_shadowColorDark="@color/neumorph_dark_shadow"
    app:neumorph_backgroundColor="@color/Background"
    app:neumorph_shapeType="flat">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="15dp"
        android:paddingBottom="15dp">

        <ImageView
            android:id="@+id/SetLogo"
            android:contentDescription="@string/set_logo"
            android:layout_width="160dp"
            android:layout_height="90dp"
            android:layout_gravity="center" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:orientation="horizontal"
            android:paddingLeft="15dp"
            android:paddingRight="15dp">

            <ImageView
                android:id="@+id/SetSymbol"
                android:contentDescription="@string/set_symbol"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:gravity="center_vertical"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:layout_weight="2"/>

            <TextView
                android:id="@+id/SetName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textAlignment="center"
                android:layout_weight="7"
                style="@style/textbold"/>

            <TextView
                android:id="@+id/SetCards"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textAlignment="center"
                android:layout_weight="4"
                style="@style/textbold"/>

        </LinearLayout>

    </LinearLayout>

</soup.neumorphism.NeumorphCardView>