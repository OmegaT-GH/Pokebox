<?xml version="1.0" encoding="utf-8"?>
<soup.neumorphism.NeumorphCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="2dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackgroundBorderless"
    app:neumorph_shadowElevation="1dp"
    app:neumorph_shadowColorLight="@color/neumorph_light_shadow"
    app:neumorph_shadowColorDark="@color/neumorph_dark_shadow"
    app:neumorph_backgroundColor="@color/Background"
    app:neumorph_shapeType="pressed">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp">

        <CheckBox
            android:id="@+id/cbFilterOption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:button="@drawable/checkbox_selector"
            android:clickable="false"
            android:focusable="false" />

        <TextView
            android:id="@+id/tvFilterLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/text"
            android:textSize="13sp"
            android:textColor="@color/text_primary" />

    </LinearLayout>

</soup.neumorphism.NeumorphCardView>