<?xml version="1.0" encoding="utf-8"?>
<soup.neumorphism.NeumorphCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:neumorph_shadowElevation="4dp"
    app:neumorph_shadowColorLight="@color/neumorph_light_shadow"
    app:neumorph_shadowColorDark="@color/neumorph_dark_shadow"
    app:neumorph_backgroundColor="@color/Background"
    app:neumorph_shapeType="flat">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/ivLogCardImage"
            android:layout_width="60dp"
            android:layout_height="84dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="@string/card_image"
            android:scaleType="fitCenter"
            android:src="@drawable/placeholdercard" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvLogCardName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="14sp"
                android:text="Card Name" />

            <TextView
                android:id="@+id/tvLogCardSet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:text="Set Name #123" />

            <TextView
                android:id="@+id/tvLogMovement"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:text="Aumentada la cantidad de 1 a 2" />

            <TextView
                android:id="@+id/tvLogTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:text="Hace 5 minutos" />

        </LinearLayout>

    </LinearLayout>

</soup.neumorphism.NeumorphCardView>
